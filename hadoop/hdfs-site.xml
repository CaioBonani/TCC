<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  hdfs-site.xml - Configuração HDFS
  Lambda Architecture - TCC DATASUS
  Block size: 128MB | Replicação: 1 (dev)
-->
<configuration>
    <!-- Fator de replicação (1 para ambiente de desenvolvimento) -->
    <property>
        <name>dfs.replication</name>
        <value>1</value>
    </property>

    <!-- Tamanho do bloco: 128MB conforme descrito no TCC -->
    <property>
        <name>dfs.blocksize</name>
        <value>134217728</value>
    </property>

    <!-- Desabilitar verificação de permissões para facilitar acesso -->
    <property>
        <name>dfs.permissions.enabled</name>
        <value>false</value>
    </property>

    <!-- Habilitar WebHDFS -->
    <property>
        <name>dfs.webhdfs.enabled</name>
        <value>true</value>
    </property>

    <!-- Diretórios de armazenamento -->
    <property>
        <name>dfs.namenode.name.dir</name>
        <value>file:///hadoop/dfs/name</value>
    </property>
    <property>
        <name>dfs.datanode.data.dir</name>
        <value>file:///hadoop/dfs/data</value>
    </property>

    <!-- Aceitar conexão de qualquer host (acesso VPN) -->
    <property>
        <name>dfs.namenode.datanode.registration.ip-hostname-check</name>
        <value>false</value>
    </property>

    <!-- Suporte a arquivos grandes para processamento Spark -->
    <property>
        <name>dfs.namenode.handler.count</name>
        <value>20</value>
    </property>
</configuration>
