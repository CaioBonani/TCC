# =============================================================
# Lambda Architecture - Docker Environment Variables
# =============================================================

# --- Kafka ---
KAFKA_BROKER_ID=1
KAFKA_TOPIC=datasus-internacoes
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# --- HDFS ---
HDFS_REPLICATION=1
HDFS_BLOCKSIZE=134217728

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=3

# --- Cassandra ---
CASSANDRA_CLUSTER_NAME=LambdaCluster
CASSANDRA_DC=datacenter1
CASSANDRA_KEYSPACE=lambda_arch

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_INSTALL_PLUGINS=

# --- Prometheus ---
PROMETHEUS_RETENTION=15d
