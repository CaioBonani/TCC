# =============================================================
# Lambda Architecture - Docker Environment Variables
# =============================================================

# --- Kafka ---
KAFKA_BROKER_ID=1
KAFKA_TOPIC=datasus-internacoes
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# --- HDFS ---
HDFS_REPLICATION=1
HDFS_BLOCKSIZE=134217728

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=3
SPARK_JOB_CORES=1
SPARK_JOB_MEMORY=512m
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.4.0
SPARK_CASSANDRA_PACKAGE=com.datastax.spark:spark-cassandra-connector_2.12:3.4.1

# --- Jobs 24/7 ---
PRODUCER_BATCH_SIZE=20
PRODUCER_INTERVAL_SECONDS=1.0
PRODUCER_EXTRA_ARGS=--no-order
BATCH_INTERVAL_SECONDS=3600

# --- Cassandra ---
CASSANDRA_CLUSTER_NAME=LambdaCluster
CASSANDRA_DC=datacenter1
CASSANDRA_KEYSPACE=lambda_arch
CASSANDRA_VIEWER_MAX_LIMIT=500

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_INSTALL_PLUGINS=

# --- Prometheus ---
PROMETHEUS_RETENTION=15d
